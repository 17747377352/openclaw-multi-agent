<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.novel2video.mapper.NovelProjectMapper">

    <resultMap id="BaseResultMap" type="com.novel2video.entity.NovelProject">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="author" property="author"/>
        <result column="original_file_path" property="originalFilePath"/>
        <result column="status" property="status"/>
        <result column="total_chapters" property="totalChapters"/>
        <result column="total_words" property="totalWords"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectProjects" resultMap="BaseResultMap">
        SELECT id, user_id, title, author, original_file_path as file_path, status, total_chapters, 0 as total_groups, created_at, updated_at
        FROM novel_project
        <where>
            <if test="params.status != null">
                AND status = #{params.status}
            </if>
            <if test="params.keyword != null">
                AND (title LIKE #{params.keyword} OR author LIKE #{params.keyword})
            </if>
        </where>
        ORDER BY ${params.orderBy}
        LIMIT #{params.offset}, #{params.limit}
    </select>

</mapper>